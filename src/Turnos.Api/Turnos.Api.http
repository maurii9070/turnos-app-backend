@Api_HostAddress = http://localhost:5092/api
@contentType = application/json

# ==========================================
# Autenticación
# ==========================================

###
# Registrar un nuevo paciente (manual)
POST {{Api_HostAddress}}/auth/register-patient
Content-Type: {{contentType}}

{
  "dni": "40565353",
  "firstName": "Maricio",
  "lastName": "Velazquez",
  "password": "123123",
  "dateOfBirth": "1996-10-29"
}

###
# @name login
# Iniciar sesión (devuelve access token en body + refresh token en cookie)
POST {{Api_HostAddress}}/auth/login
Content-Type: {{contentType}}

{
  "dni": "40565355",
  "password": "123123"
}
###
@accessToken = {{login.response.body.data.accessToken}}

###
# Refrescar access token (lee refresh token de la cookie y rota)
POST {{Api_HostAddress}}/auth/refresh

###
# Cerrar sesión (revoca refresh token y borra la cookie)
POST {{Api_HostAddress}}/auth/logout

# ==========================================
# Especialidades (algunos públicos, otros SuperAdmin)
# ==========================================

###
# @name createSpecialty
# Crear una nueva especialidad (requiere Bearer token de SuperAdmin)
POST {{Api_HostAddress}}/specialties
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Test especialidad p/doctor",
  "description": "Descripción de la especialidad de prueba"
}

###
# Listar todas las especialidades activas (cualquier usuario autenticado)
GET {{Api_HostAddress}}/specialties
Authorization: Bearer {{accessToken}}

###
# @name getSpecialtyById
# Obtener especialidad por ID (cualquier usuario autenticado)
GET {{Api_HostAddress}}/specialties/{{createSpecialty.response.body.data.id}}
Authorization: Bearer {{accessToken}}

###
# @name updateSpecialty
# Actualizar especialidad (requiere SuperAdmin)
PUT {{Api_HostAddress}}/specialties/{{createSpecialty.response.body.data.id}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Test especialidad actualizada",
  "description": "Descripción actualizada"
}

###
# Eliminar especialidad (soft-delete, requiere SuperAdmin)
DELETE {{Api_HostAddress}}/specialties/{{createSpecialty.response.body.data.id}}
Authorization: Bearer {{accessToken}}

###

# ==========================================
# Doctores (algunos públicos, otros SuperAdmin)
# ==========================================

###  @name createDoctor
# Crear un doctor (requiere SuperAdmin)
POST {{Api_HostAddress}}/doctors
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "dni": "40565355",
  "firstName": "Juan",
  "lastName": "Pérez",
  "password": "123123",
  "specialtyId": "{{createSpecialty.response.body.data.id}}",
  "licenseNumber": "MN-12345",
  "consultationPrice": 5000.00,
  "email": "juan.perez@example.com",
  "phone": "1144445555"
}

###  @name createDoctor2
# Crear otro doctor (para listar y filtrar)
POST {{Api_HostAddress}}/doctors
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "dni": "30666222",
  "firstName": "María",
  "lastName": "García",
  "password": "123123",
  "specialtyId": "{{createSpecialty.response.body.data.id}}",
  "licenseNumber": "MN-67890",
  "consultationPrice": 6000.00
}

###  @name createDoctor3
# Crear doctor sin token (debería dar 401)
POST {{Api_HostAddress}}/doctors
Content-Type: {{contentType}}

{
  "dni": "30777333",
  "firstName": "Test",
  "lastName": "Doctor",
  "password": "123456",
  "specialtyId": "{{createSpecialty.response.body.data.id}}",
  "licenseNumber": "MN-99999",
  "consultationPrice": 4000.00
}

###  @name listDoctors
# Listar todos los doctores activos (público)
GET {{Api_HostAddress}}/doctors

###  @name listDoctorsFiltered
# Listar doctores filtrados por especialidad
GET {{Api_HostAddress}}/doctors?specialtyId={{createSpecialty.response.body.data.id}}

###  @name getDoctor
# Obtener doctor por ID con especialidad y horarios (público)
GET {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}

###  @name updateDoctor
# Actualizar doctor (requiere SuperAdmin)
PUT {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "specialtyId": "{{createSpecialty.response.body.data.id}}",
  "licenseNumber": "MN-54321",
  "consultationPrice": 5500.00
}

###  @name deactivateDoctor
# Desactivar doctor (soft-delete, SuperAdmin)
DELETE {{Api_HostAddress}}/doctors/{{createDoctor2.response.body.data.doctorId}}
Authorization: Bearer {{accessToken}}

###

# ==========================================
# Horarios semanales del doctor (Schedule)
# ==========================================

###  @name getSchedules
# Obtener horarios semanales del doctor (público)
GET {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/schedules

###  @name setSchedules
# Definir horarios semanales (SuperAdmin o doctor propietario)
PUT {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/schedules
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "schedules": [
    { "dayOfWeek": "Monday",    "startTime": "09:00", "endTime": "13:00" },
    { "dayOfWeek": "Monday",    "startTime": "15:00", "endTime": "18:00" },
    { "dayOfWeek": "Tuesday",   "startTime": "09:00", "endTime": "17:00" },
    { "dayOfWeek": "Wednesday", "startTime": "09:00", "endTime": "17:00" },
    { "dayOfWeek": "Thursday",  "startTime": "09:00", "endTime": "17:00" },
    { "dayOfWeek": "Friday",    "startTime": "09:00", "endTime": "13:00" }
  ]
}

#

# ==========================================
# Disponibilidades por fecha (DoctorAvailability)
# ==========================================

###  @name listAvailabilities
# Listar disponibilidades por fecha (público, con filtro opcional de rango)
GET {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/availabilities?from=2026-06-01&to=2026-06-30

###  @name createAvailability
# Agregar día extra disponible (SuperAdmin o doctor propietario)
POST {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/availabilities
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "date": "2026-06-15",
  "startTime": "10:00",
  "endTime": "14:00",
  "isAvailable": true
}

###  @name createBlockedDay
# Bloquear un día concreto (SuperAdmin o doctor propietario)
POST {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/availabilities
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "date": "2026-06-17",
  "startTime": "09:00",
  "endTime": "17:00",
  "isAvailable": false
}

###  @name updateAvailability
# Modificar una disponibilidad existente
PUT {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/availabilities/{{createAvailability.response.body.data.id}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "date": "2026-06-15",
  "startTime": "11:00",
  "endTime": "15:00",
  "isAvailable": true
}

###  @name deleteAvailability
# Eliminar una disponibilidad (vuelve al schedule semanal)
DELETE {{Api_HostAddress}}/doctors/{{createDoctor.response.body.data.doctorId}}/availabilities/{{createAvailability.response.body.data.id}}
Authorization: Bearer {{accessToken}}

###

# ==========================================
# Turnos (Appointments) — requiere token de Patient salvo que se indique
# ==========================================

###
#  @name loginAsPatient
# Login como paciente (40565353) para crear/cancelar turnos
POST {{Api_HostAddress}}/auth/login
Content-Type: {{contentType}}

{
  "dni": "40565353",
  "password": "123123"
}
###
@patientToken = {{loginAsPatient.response.body.data.accessToken}}

###  @name createAppointment
# Crear un turno (Patient) — usa patientToken
POST {{Api_HostAddress}}/appointments
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "doctorId": "58dd9cc8-1562-477b-9b08-38290b3e40c6",
  "date": "2026-06-16",
  "startTime": "09:00",
  "notes": "Consulta por dolor de espalda"
}

###  @name createAppointment2
# Crear otro turno para listar varios
POST {{Api_HostAddress}}/appointments
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "doctorId": "{{createDoctor.response.body.data.doctorId}}",
  "date": "2026-06-18",
  "startTime": "11:00",
  "notes": "Control de rutina"
}

###  @name listMyAppointments
# Listar mis turnos (Patient o Doctor)
GET {{Api_HostAddress}}/appointments/me
Authorization: Bearer {{patientToken}}

#  @name loginAsDoctor
### Login como Doctor para ver su listado dedicado
POST {{Api_HostAddress}}/auth/login
Content-Type: {{contentType}}

{
  "dni": "40565355",
  "password": "123123"
}
###
@doctorToken = {{loginAsDoctor.response.body.data.accessToken}}

###  @name listDoctorAppointments
# Listar turnos del doctor (solo Confirmed y Completed)
GET {{Api_HostAddress}}/doctors/me/appointments
Authorization: Bearer {{doctorToken}}

###  @name getAppointment
# Obtener detalle de un turno
GET {{Api_HostAddress}}/appointments/17e7617d-5b8b-412e-a022-a25388ac5998
Authorization: Bearer {{patientToken}}

###  @name cancelAppointment
# Cancelar un turno (solo PendingPayment)
PUT {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/cancel
Authorization: Bearer {{patientToken}}

###  @name confirmAppointment
# Confirmar un turno (Admin/SuperAdmin) — usa accessToken (SuperAdmin)
PUT {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/confirm
Authorization: Bearer {{accessToken}}

###  @name listAppointments
# Listar todos los turnos (Admin/SuperAdmin) — filtro opcional por status
GET {{Api_HostAddress}}/appointments?status=PendingReview
Authorization: Bearer {{accessToken}}

###  @name getDoctorAppointments
# Obtener turnos ocupados de un doctor en una fecha (cualquier autenticado)
GET {{Api_HostAddress}}/doctors/58dd9cc8-1562-477b-9b08-38290b3e40c6/appointments?date=2026-06-16
Authorization: Bearer {{patientToken}}

###  @name completeAppointment
# Completar un turno (requiere token de Doctor logueado)
# Primero logueate como el doctor:
#   POST {{Api_HostAddress}}/auth/login {"dni": "40565355", "password": "123123"}
# Luego usa ese token acá
PUT {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/complete
Authorization: Bearer <doctorAccessToken>

###

# ==========================================
# Pagos (Payments)
# ==========================================

###  @name createPaymentCash
# Crear pago en efectivo para un turno (Patient dueño del turno)
# → Appointment sigue en PendingPayment (pago presencial)
POST {{Api_HostAddress}}/appointments/370c28fd-3f1c-4996-a71c-aed18163f223/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "Cash",
  "receiptUrl": null
}

###  @name createPaymentTransfer
# Crear pago por transferencia con comprobante (Patient)
# → Appointment pasa a PendingReview (admin/doctor debe aprobar)
POST {{Api_HostAddress}}/appointments/370c28fd-3f1c-4996-a71c-aed18163f223/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "Transfer",
  "receiptUrl": "https://example.com/comprobantes/transfer-12345.jpg"
}

###  @name createPaymentMercadoPago
# Crear pago con MercadoPago (debe fallar con 400 — se gestiona en otro endpoint)
POST {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "MercadoPago",
  "receiptUrl": null
}

###  @name createPaymentIdempotent
# Reintentar crear pago cuando ya existe uno Pending (idempotencia)
# → devuelve 200 con el mismo Payment (no error)
POST {{Api_HostAddress}}/appointments/{{createAppointment2.response.body.data.id}}/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "Transfer",
  "receiptUrl": "https://example.com/comprobantes/transfer-retry.jpg"
}

###  @name createPaymentInvalidReceipt
# Crear pago con ReceiptUrl inválida (debe fallar con 400)
POST {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "Transfer",
  "receiptUrl": "not-a-valid-url"
}

###  
# @name loginAsAdmin
# Login como SuperAdmin (DNI 40565353 ya logueado arriba, este es solo un placeholder
# si necesitás un token fresco de admin)
POST {{Api_HostAddress}}/auth/login
Content-Type: {{contentType}}

{
  "dni": "40565354",
  "password": "123123"
}
###
@adminToken = {{loginAsAdmin.response.body.data.accessToken}}

###  @name approvePayment
# Aprobar un pago (Admin/SuperAdmin o Doctor dueño de la cita)
# → PaidAt se setea a UtcNow; la cita sigue en PendingReview hasta ConfirmAppointment
PUT {{Api_HostAddress}}/payments/e29ed4d0-64d6-40aa-bfab-5cc58d6579a8
Content-Type: {{contentType}}
Authorization: Bearer {{adminToken}}

{
  "status": "Approved"
}

###  @name rejectPayment
# Rechazar un pago (Admin/SuperAdmin o Doctor dueño de la cita)
PUT {{Api_HostAddress}}/payments/2c884c85-774c-4313-91df-7393a52e15ff
Content-Type: {{contentType}}
Authorization: Bearer {{adminToken}}

{
  "status": "Rejected"
}

###  @name updatePaymentInvalidStatus
# Intentar actualizar con status Pending (debe fallar con 400)
PUT {{Api_HostAddress}}/payments/370c28fd-3f1c-4996-a71c-aed18163f223
Content-Type: {{contentType}}
Authorization: Bearer {{adminToken}}

{
  "status": "Approved"
}

###  @name createPaymentAfterReject
# Crear pago nuevo después de un rechazo (reemplaza el Rejected)
POST {{Api_HostAddress}}/appointments/2c884c85-774c-4313-91df-7393a52e15ff/payment
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "method": "Transfer",
  "receiptUrl": "https://example.com/comprobantes/transfer-after-reject.jpg"
}

###

# ==========================================
# Archivos de Turno (AppointmentFiles)
# ==========================================

###  @name uploadPatientReceipt
# Subir comprobante de pago como Patient (dueño del turno)
# → Appointment pasa de PendingPayment a PendingReview + actualiza Payment.ReceiptUrl
# Nota: Reemplazar {appointmentId} con el ID del turno en PendingPayment
POST {{Api_HostAddress}}/appointments/17e7617d-5b8b-412e-a022-a25388ac5998/files
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "fileName": "comprobante_falso.png",
  "fileType": "image/png",
  "filePathOrUrl": "https://kupatmndlliglhoyyvip.supabase.co/storage/v1/object/public/appointment-files/patient-file/comprobante_falso.png"
}

###  @name uploadPatientReceiptPdf
# Subir comprobante en PDF como Patient
POST {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/files
Content-Type: {{contentType}}
Authorization: Bearer {{{{accessToken}}}}

{
  "fileName": "comprobante_transferencia.pdf",
  "fileType": "application/pdf",
  "filePathOrUrl": "https://xxx.supabase.co/storage/v1/object/public/comprobantes/usuario-123/transferencia.pdf"
}

###  @name uploadDoctorDocument
# Subir archivo médico como Doctor (no cambia estado del turno)
# Nota: Primero logueate como el doctor del turno y usa su token acá
POST {{Api_HostAddress}}/appointments/17e7617d-5b8b-412e-a022-a25388ac5998/files
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "fileName": "resultado_estudio.jpg",
  "fileType": "image/jpeg",
  "filePathOrUrl": "https://kupatmndlliglhoyyvip.supabase.co/storage/v1/object/public/appointment-files/doctor-file/archivo-medico-falso.jpg"
}

###  @name uploadFileInvalidUrl
# Subir archivo con URL inválida (debe fallar con 400)
POST {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/files
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "fileName": "comprobante.jpg",
  "fileType": "image/jpeg",
  "filePathOrUrl": "not-a-valid-url"
}

###  @name uploadFileNoAuth
# Subir archivo sin token (debe fallar con 401)
POST {{Api_HostAddress}}/appointments/{{createAppointment.response.body.data.id}}/files
Content-Type: {{contentType}}

{
  "fileName": "comprobante.jpg",
  "fileType": "image/jpeg",
  "filePathOrUrl": "https://xxx.supabase.co/storage/v1/object/public/comprobantes/test.jpg"
}

###  @name uploadFileNotFound
# Subir archivo a un turno inexistente (debe fallar con 404)
POST {{Api_HostAddress}}/appointments/00000000-0000-0000-0000-000000000000/files
Content-Type: {{contentType}}
Authorization: Bearer {{patientToken}}

{
  "fileName": "comprobante.jpg",
  "fileType": "image/jpeg",
  "filePathOrUrl": "https://xxx.supabase.co/storage/v1/object/public/comprobantes/test.jpg"
}

###

# ==========================================
# Perfil de Usuario
# ==========================================

###  @name getCurrentUser
# Obtener perfil del usuario autenticado (SuperAdmin, Doctor o Patient)
GET {{Api_HostAddress}}/users/me
Authorization: Bearer {{accessToken}}

###  @name updateProfile
# Actualizar nombre, email, teléfono y fecha de nacimiento (Patient)
PUT {{Api_HostAddress}}/users/me
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "firstName": "Mauricio",
  "lastName": "Velazquez",
  "email": "mauricio@example.com",
  "phone": "1144445555",
  "dateOfBirth": "1996-10-29"
}

###  @name changePassword
# Cambiar contraseña (requiere contraseña actual)
PUT {{Api_HostAddress}}/users/me/password
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "currentPassword": "123123",
  "newPassword": "newPass456"
}

###
